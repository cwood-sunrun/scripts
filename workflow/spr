#!/bin/bash
set -euo pipefail

if [ $# -ne 1 ]; then
  echo "Usage: $0 <CHANGE_DESCRIPTION>" >&2
  exit 1
fi

CHANGE_DESCRIPTION="$1"
TARGET_SLACK_GROUP=""

URL=$(gh pr view --json url -q .url)
FILE_COUNT=$(gh pr view --json files --jq '.files | length')

if [ "$FILE_COUNT" -lt 2 ]; then
  PR_SIZE_CATEGORY="Micro"
elif [ "$FILE_COUNT" -le 3 ]; then
  PR_SIZE_CATEGORY="Tiny"
elif [ "$FILE_COUNT" -le 5 ]; then
  PR_SIZE_CATEGORY="Small"
else
  PR_SIZE_CATEGORY=""
fi

if [ -n "$PR_SIZE_CATEGORY" ]; then
  MESSAGE="{TARGET_SLACK_GROUP} {PR_SIZE_CATEGORY} pr to ${CHANGE_DESCRIPTION}: ${URL}"
else
  MESSAGE="{TARGET_SLACK_GROUP} pr to ${CHANGE_DESCRIPTION}: ${URL}"
fi

echo "$MESSAGE" | pbcopy
echo "Copied to clipboard: $MESSAGE"
