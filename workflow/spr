#!/bin/bash
set -euo pipefail

if [ $# -ne 1 ]; then
  echo "Usage: $0 <CHANGE_DESCRIPTION>" >&2
  exit 1
fi

CHANGE_DESCRIPTION="$1"
TARGET_SLACK_GROUP=""
DEFAULT_BRANCH="develop"

URL=$(gh pr view --json url -q .url)
FILE_COUNT=$(gh pr view --json files --jq '.files | length')

MERGE_BASE=$(git merge-base HEAD "origin/${DEFAULT_BRANCH}" 2>/dev/null || git merge-base HEAD "${DEFAULT_BRANCH}" 2>/dev/null || "")
INSERTIONS=$(git diff --stat "$MERGE_BASE" | tail -1 | grep -oE '[0-9]+ insertion' | grep -oE '[0-9]+' || echo 0)
DELETIONS=$(git diff --stat "$MERGE_BASE" | tail -1 | grep -oE '[0-9]+ deletion' | grep -oE '[0-9]+' || echo 0)

MESSAGE="${TARGET_SLACK_GROUP} pr to ${CHANGE_DESCRIPTION} [+${INSERTIONS}, -${DELETIONS}]: ${URL}"

echo "$MESSAGE" | pbcopy
echo "Copied to clipboard: $MESSAGE"
